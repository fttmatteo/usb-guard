<Window x:Class="USBGuard.App.Views.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:viewmodels="clr-namespace:USBGuard.App.ViewModels"
        mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=viewmodels:LockScreenViewModel}"
        Title="USB Guard Lock" WindowStyle="None" Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        Background="#0F172A" Foreground="White">


    <Grid>
        <Border CacheMode="BitmapCache">
            <Border.Background>
                <ImageBrush ImageSource="{Binding CurrentWallpaper}" Stretch="UniformToFill"/>
            </Border.Background>
            <Border.Effect>
                <BlurEffect Radius="20" KernelType="Gaussian"/>
            </Border.Effect>
        </Border>
        
        <Border Background="#60000000"/>



        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <TextBlock Text="{Binding CurrentTime}" Foreground="White" FontSize="140" FontWeight="Thin" HorizontalAlignment="Center" Margin="0,0,0,-25">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.5" Color="Black" />
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="{Binding CurrentDate}" Foreground="#94A3B8" FontSize="28" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,0,0,80" />
            
            <Border Width="420" Padding="40" CornerRadius="16" Background="#15FFFFFF" BorderBrush="#35FFFFFF" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="10" BlurRadius="40" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    
                    <Grid Width="90" Height="90" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Image Source="pack://application:,,,/Assets/guard.ico" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>

                    <TextBlock Text="Sistema Protegido" Foreground="White" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Inserte de vuelta su memoria USB para desarmar la seguridad del equipo." 
                               Foreground="#CBD5E1" FontSize="14" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="20"/>
                    
                    <Border Height="1" Background="#20FFFFFF" Margin="0,0,0,25"/>

                    <TextBlock Text="¿Extravió la llave? Utilice su acceso manual:" Foreground="#94A3B8" FontSize="13" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    
                    <ui:PasswordBox Password="{Binding EmergencyPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Llave Maestra de Recuperación" Icon="Key20" Height="45" FontSize="15" Margin="0,0,0,5"
                                    IsEnabled="{Binding IsInputEnabled}"/>
                    
                    <TextBlock Text="{Binding CooldownMessage}" Foreground="#EF4444" FontSize="13" TextAlignment="Center" FontWeight="SemiBold" Height="20" Margin="0,0,0,10"/>
                    
                    <ui:Button Content="Desbloquear acceso" Command="{Binding TryUnlockCommand}" Appearance="Primary" HorizontalAlignment="Stretch" Height="45" FontSize="15" FontWeight="Medium"
                               IsEnabled="{Binding IsInputEnabled}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="LockOpen20"/>
                        </ui:Button.Icon>
                    </ui:Button>

                </StackPanel>
            </Border>
            
            <TextBlock Text="USB Guard v1.0.0" Foreground="#475569" FontSize="12" HorizontalAlignment="Center" Margin="0,40,0,0" />
        </StackPanel>
    </Grid>
</Window>
