<Window x:Class="USBGuard.App.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Verificación Requerida" Height="220" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow" Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Ingresa la Contraseña de Seguridad actual para autorizar la eliminación de esta memoria:" TextWrapping="Wrap" Margin="0,0,0,15" />
        <ui:PasswordBox x:Name="PwdBox" PlaceholderText="Tu contraseña" Margin="0,0,0,20" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Cancelar" Click="BtnCancel_Click" Margin="0,0,15,0" />
            <ui:Button Content="Confirmar" Appearance="Primary" Click="BtnOk_Click" />
        </StackPanel>
    </StackPanel>
</Window>
