## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
/.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# VSTest / MSTest / NUnit Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml

# NuGet Packages
*.nupkg
packages/

# Rider / IntelliJ / VS Code
.idea/
*.sln.iml
.vscode/
workspace.xml

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Windows Caches
Thumbs.db
ehthumbs.db
Desktop.ini

# Criptografía / Certificados locales (Previene filtración de firmas)
*.pfx
*.p12
*.snk
*.key

# Archivos de publicación
*.publishsettings
app.publish/
